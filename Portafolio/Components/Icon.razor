@* Shared icon primitive used across navigation, pillars, and metadata chips. *@
<svg class="@Class" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @switch (Name.ToLowerInvariant())
    {
        case "home":
            <path d="M3 10.5L12 3l9 7.5"></path>
            <path d="M5 9.5V21h14V9.5"></path>
            break;
        case "user":
            <circle cx="12" cy="8" r="4"></circle>
            <path d="M4 21c1.6-3.7 4.2-5.5 8-5.5S18.4 17.3 20 21"></path>
            break;
        case "folder":
            <path d="M3 7h6l2 2h10v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7z"></path>
            break;
        case "layers":
            <path d="M12 3l9 4.5-9 4.5-9-4.5L12 3z"></path>
            <path d="M3 12.5L12 17l9-4.5"></path>
            <path d="M3 17.5L12 22l9-4.5"></path>
            break;
        case "file":
            <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
            <path d="M14 2v5h5"></path>
            break;
        case "mail":
            <path d="M3 6h18v12H3z"></path>
            <path d="M3 7l9 7 9-7"></path>
            break;
        case "bot":
            <rect x="5" y="7" width="14" height="12" rx="2"></rect>
            <path d="M12 3v4"></path>
            <circle cx="9.5" cy="12" r="1"></circle>
            <circle cx="14.5" cy="12" r="1"></circle>
            break;
        case "cpu":
            <rect x="7" y="7" width="10" height="10" rx="1"></rect>
            <path d="M9 1v3M15 1v3M9 20v3M15 20v3M1 9h3M1 15h3M20 9h3M20 15h3"></path>
            break;
        case "chip":
            <rect x="7" y="7" width="10" height="10" rx="1"></rect>
            <path d="M3 9h4M3 15h4M17 9h4M17 15h4M9 3v4M15 3v4M9 17v4M15 17v4"></path>
            break;
        case "network":
            <circle cx="12" cy="5" r="2"></circle>
            <circle cx="5" cy="19" r="2"></circle>
            <circle cx="19" cy="19" r="2"></circle>
            <path d="M12 7v5M12 12l-5 5M12 12l5 5"></path>
            break;
        case "arrow-right":
            <path d="M5 12h14"></path>
            <path d="M13 6l6 6-6 6"></path>
            break;
        default:
            <circle cx="12" cy="12" r="8"></circle>
            break;
    }
</svg>

@code {
    [Parameter]
    public string Name { get; set; } = "circle";

    [Parameter]
    public string Class { get; set; } = "icon";
}

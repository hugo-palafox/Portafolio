@page "/"
@inject HomeContentService HomeContentService
@inject ProjectService ProjectService

<PageTitle>Hugo Palafox | Industrial Systems Architect</PageTitle>

<SectionContainer>
    <div class="hero-grid">
        <div>
            <p class="eyebrow">Engineering Portfolio</p>
            <h1>@HomeContent.Name</h1>
            <h2 class="hero-headline">@HomeContent.Headline</h2>
            <p class="lead">@HomeContent.Subheadline</p>
            <p>@HomeContent.Description</p>
            <div class="hero-actions">
                <ButtonLink Href="/projects" Text="View Projects" />
                <ButtonLink Href="/assets/resume/Hugo-Palafox-Resume.pdf" Text="Download Resume" Secondary="true" Download="true" />
                <ButtonLink Href="/contact" Text="Contact" Secondary="true" />
            </div>
        </div>
        <div class="media media-hero">
            <div class="media-placeholder">
                <span>Architecture Snapshot Placeholder</span>
            </div>
        </div>
    </div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Capabilities" Title="Multidisciplinary Delivery Pillars" Description="Technical depth across robotics, controls, embedded systems, and industrial software architecture." />
    <div class="grid grid-2">
        @foreach (var pillar in HomeContent.Pillars)
        {
            <PillarCard Pillar="@pillar" @key="pillar.Title" />
        }
    </div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Featured Work" Title="Selected Engineering Case Studies" Description="Projects focused on system integration, deployment reliability, and production scalability." />
    <div class="grid grid-3">
        @foreach (var project in FeaturedProjects)
        {
            <ProjectCard Project="@project" @key="project.Id" />
        }
    </div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Impact Metrics" Title="Engineering Outcomes" />
    <MetricsStrip Metrics="@HomeContent.Metrics" />
</SectionContainer>

<SectionContainer>
    <div class="card cta-strip">
        <div>
            <h3>Looking for engineering leadership that can bridge machine controls and software systems?</h3>
            <p>Explore case studies, architecture decisions, and implementation outcomes across robotics, controls, and edge platforms.</p>
        </div>
        <div class="cta-actions">
            <ButtonLink Href="/projects" Text="View Projects" />
            <ButtonLink Href="/assets/resume/Hugo-Palafox-Resume.pdf" Text="Download Resume" Secondary="true" Download="true" />
            <ButtonLink Href="/contact" Text="Contact" Secondary="true" />
        </div>
    </div>
</SectionContainer>

@code {
    private HomeContent HomeContent { get; set; } = new();

    private IReadOnlyList<Project> FeaturedProjects { get; set; } = Array.Empty<Project>();

    protected override void OnInitialized()
    {
        HomeContent = HomeContentService.GetContent();
        FeaturedProjects = ProjectService.GetFeaturedProjects();
    }
}

@inherits LayoutComponentBase
@inject HomeContentService HomeContentService

<div class="app-shell">
    <header class="top-nav">
        <div class="top-nav-inner">
            <a class="brand-link" href="/">Hugo Palafox</a>

            <button class="mobile-menu-button" @onclick="ToggleNav" aria-expanded="@IsMobileNavOpen" aria-label="Toggle navigation">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <nav class="top-links" aria-label="Primary">
                @foreach (var item in NavItems)
                {
                    <NavLink class="top-link" href="@item.Href" Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)">
                        @item.Title
                    </NavLink>
                }
            </nav>
        </div>
    </header>

    <div class="drawer-overlay @(IsMobileNavOpen ? "open" : string.Empty)" @onclick="CloseNav"></div>
    <aside class="mobile-drawer @(IsMobileNavOpen ? "open" : string.Empty)">
        <nav aria-label="Mobile navigation">
            <ul class="drawer-links">
                @foreach (var item in NavItems)
                {
                    <li @key="item.Href">
                        <NavLink class="drawer-link" href="@item.Href" Match="@(item.Href == "/" ? NavLinkMatch.All : NavLinkMatch.Prefix)" @onclick="CloseNav">
                            <Icon Name="@item.IconName" Class="drawer-icon" />
                            <span>@item.Title</span>
                        </NavLink>
                    </li>
                }
            </ul>
        </nav>
    </aside>

    <main class="content-shell">
        @Body
    </main>
</div>

@code {
    private bool IsMobileNavOpen { get; set; }

    private IReadOnlyList<NavItem> NavItems { get; set; } = Array.Empty<NavItem>();

    protected override void OnInitialized()
    {
        NavItems = HomeContentService.GetNavigationItems();
    }

    private void ToggleNav()
    {
        IsMobileNavOpen = !IsMobileNavOpen;
    }

    private void CloseNav()
    {
        IsMobileNavOpen = false;
    }
}

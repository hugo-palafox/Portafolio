@page "/"
@inject HomeContentService HomeContentService
@inject ProjectService ProjectService

<PageTitle>Hugo Palafox | Robotics & Automation Systems Engineer</PageTitle>

<SectionContainer>
    <div class="hero-grid">
        <div class="hero-copy">
            <p class="eyebrow">Engineering Portfolio</p>
            <h1>@HomeContent.Name</h1>
            <h2 class="hero-headline">@HomeContent.Headline</h2>
            <p class="lead">@HomeContent.Subheadline</p>
            <p class="hero-description">@HomeContent.Description</p>
            <div class="hero-actions">
                <ButtonLink Href="/projects" Text="View Projects" />
                <ButtonLink Href="/assets/resume/Hugo-Palafox-Resume.pdf" Text="Download Resume" Secondary="true" Download="true" />
                <ButtonLink Href="/contact" Text="Contact" Secondary="true" />
            </div>
        </div>
        <section class="architecture-block" aria-label="Automation system architecture">
            <header class="architecture-header">
                <p class="architecture-title">Automation System Architecture</p>
                <p class="architecture-support">Robotics, edge systems, and industrial software integrated into one production architecture.</p>
            </header>
            <div class="architecture-flow" role="img" aria-label="System architecture flow from cell layer to edge layer to platform layer">
                <section class="architecture-layer-card">
                    <h3 class="architecture-layer-title">
                        <Icon Name="bot" Class="architecture-layer-icon" />
                        Cell
                    </h3>
                    <p class="architecture-layer-summary">Robotics &middot; PLC &middot; Vision</p>
                </section>
                <div class="architecture-connector" aria-hidden="true">
                    <Icon Name="arrow-right" Class="architecture-connector-icon" />
                </div>
                <section class="architecture-layer-card">
                    <h3 class="architecture-layer-title">
                        <Icon Name="chip" Class="architecture-layer-icon" />
                        Edge
                    </h3>
                    <p class="architecture-layer-summary">Runtime &middot; Provisioning &middot; Adapters</p>
                </section>
                <div class="architecture-connector" aria-hidden="true">
                    <Icon Name="arrow-right" Class="architecture-connector-icon" />
                </div>
                <section class="architecture-layer-card">
                    <h3 class="architecture-layer-title">
                        <Icon Name="cloud" Class="architecture-layer-icon" />
                        Platform
                    </h3>
                    <p class="architecture-layer-summary">APIs &middot; Data &middot; Dashboards</p>
                </section>
            </div>
            <div class="architecture-flow-label" aria-hidden="true">
                Cell &rarr; Edge &rarr; Platform
            </div>
        </section>
    </div>
    <div class="hero-divider" aria-hidden="true"></div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Capabilities" Title="Multidisciplinary Delivery Pillars" Description="System-level depth across robotics, controls, embedded systems, and industrial software." />
    <div class="grid grid-2">
        @foreach (var pillar in HomeContent.Pillars)
        {
            <PillarCard Pillar="@pillar" @key="pillar.Title" />
        }
    </div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Featured Work" Title="Selected Systems & Platforms" Description="Delivered systems, architecture work, and exploratory engineering across robotics, controls, embedded platforms, and industrial software." />
    <div class="grid grid-3">
        @foreach (var project in FeaturedProjects)
        {
            <ProjectCard Project="@project" @key="project.Id" />
        }
    </div>
</SectionContainer>

<SectionContainer>
    <PageHeader Eyebrow="Impact Metrics" Title="Engineering Outcomes" />
    <MetricsStrip Metrics="@HomeContent.Metrics" />
</SectionContainer>

<SectionContainer>
    <div class="card cta-strip">
        <div>
            <h3>Building scalable automation systems that integrate robotics, controls, and industrial software into production environments.</h3>
            <p>Explore delivered systems, architecture decisions, and exploratory engineering across real-world production environments.</p>
        </div>
        <div class="cta-actions">
            <ButtonLink Href="/projects" Text="View Projects" />
            <ButtonLink Href="/assets/resume/Hugo-Palafox-Resume.pdf" Text="Download Resume" Secondary="true" Download="true" />
            <ButtonLink Href="/contact" Text="Contact" Secondary="true" />
        </div>
    </div>
</SectionContainer>

@code {
    private HomeContent HomeContent { get; set; } = new();

    private IReadOnlyList<Project> FeaturedProjects { get; set; } = Array.Empty<Project>();

    protected override void OnInitialized()
    {
        HomeContent = HomeContentService.GetContent();
        FeaturedProjects = ProjectService.GetFeaturedProjects();
    }
}


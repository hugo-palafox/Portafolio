@page "/projects"
@inject ProjectService ProjectService

<PageTitle>Projects | Hugo Palafox</PageTitle>

<SectionContainer>
    <PageHeader Eyebrow="Projects" Title="Engineering Project Portfolio" Description="Engineering Project Portfolio  
Delivered systems, platform architecture, and exploratory engineering across robotics, controls, embedded edge, and OT-IT." />
    <div class="grid grid-3">
        @foreach (var project in ProjectsList)
        {
            <ProjectCard Project="@project" @key="project.Id" />
        }
    </div>
</SectionContainer>

@code {
    private IReadOnlyList<Project> ProjectsList { get; set; } = Array.Empty<Project>();

    protected override void OnInitialized()
    {
        ProjectsList = ProjectService.GetAllProjects();
    }
}

@page "/contact"

<PageTitle>Contact | Hugo Palafox</PageTitle>

<SectionContainer>
    <PageHeader Eyebrow="Contact" Title="Let's Discuss Automation and Industrial Systems" Description="For professional conversations related to robotics, automation, systems integration, and technical leadership." />
    <div class="content-grid">
        <article class="card prose">
            <h2>Contact Channels</h2>
            <p>Email: <a class="inline-link" href="mailto:hugodavidx@gmail.com">hugodavidx@gmail.com</a></p>
            <p>LinkedIn: <a class="inline-link" href="https://linkedin.com/in/hugo-palafox" target="_blank" rel="noopener noreferrer">linkedin.com/in/hugo-palafox</a></p>
            <p>GitHub: <a class="inline-link" href="https://github.com/hugo-palafox" target="_blank" rel="noopener noreferrer">github.com/hugo-palafox</a></p>
            <p class="contact-support-line">Use the form below for recruiter outreach, professional networking, or technical discussions.</p>
            <h2>Inquiry Form</h2>
            <form class="contact-form" aria-label="Professional contact inquiry form">
                <label>
                    Name
                    <input type="text" placeholder="Your name" />
                </label>
                <label>
                    Email
                    <input type="email" placeholder="you@company.com" />
                </label>
                <label>
                    Company / Organization (optional)
                    <input type="text" placeholder="Company or organization" />
                </label>
                <label>
                    Message
                    <textarea rows="5" placeholder="Project scope, timeline, and integration context"></textarea>
                </label>
                <button type="button" class="btn btn-primary" disabled>Send Message (Coming soon)</button>
                <p class="contact-form-note">I review messages personally and respond when there is a relevant professional or technical fit.</p>
            </form>
        </article>
    </div>
</SectionContainer>

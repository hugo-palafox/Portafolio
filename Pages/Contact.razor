@page "/contact"

<PageTitle>Contact | Hugo Palafox</PageTitle>

<SectionContainer>
    <PageHeader Eyebrow="Contact" Title="Let's Discuss Industrial Systems Work" Description="For architecture, integration, and technical leadership opportunities." />
    <div class="content-grid">
        <article class="card prose">
            <h2>Contact Channels</h2>
            <p>Email: <a class="inline-link" href="mailto:hugodavidx@gmail.com">hugodavidx@gmail.com</a></p>
            <p>LinkedIn: <a class="inline-link" href="https://linkedin.com/in/hugo-david-palafox" target="_blank" rel="noopener noreferrer">linkedin.com/in/hugo-palafox</a></p>
            <h2>Contact Form Placeholder</h2>
            <form class="contact-form" aria-label="Contact form placeholder">
                <label>
                    Name
                    <input type="text" placeholder="Your name" />
                </label>
                <label>
                    Email
                    <input type="email" placeholder="you@company.com" />
                </label>
                <label>
                    Message
                    <textarea rows="5" placeholder="Project scope, timeline, and integration context"></textarea>
                </label>
                <button type="button" class="btn btn-primary">Send Placeholder</button>
            </form>
        </article>
    </div>
</SectionContainer>

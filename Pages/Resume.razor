@page "/resume"

<PageTitle>Resume | Hugo Palafox</PageTitle>

<SectionContainer>
    <PageHeader Eyebrow="Resume" Title="Resume Preview & Download" Description="Review my resume directly below or download the full PDF for detailed experience, technical scope, and project delivery history." />
    <div class="resume-page-shell">
        <div class="card resume-preview-card">
            <div class="resume-cta-row">
                <ButtonLink Href="/assets/resume/Hugo-Palafox-Resume.pdf" Text="Download Resume" Download="true" />
                <ButtonLink Href="/contact" Text="Contact" Secondary="true" />
            </div>
            <header class="resume-preview-header">
                <h2 class="resume-preview-title">Resume PDF</h2>
                <p class="resume-preview-support">Preview the document inline for a quick review. Download the PDF for full-resolution viewing and printing.</p>
            </header>
            <div class="resume-preview-stage">
                <iframe
                    class="resume-preview-frame"
                    src="/assets/resume/Hugo-Palafox-Resume.pdf"
                    title="Hugo Palafox Resume PDF Preview">
                </iframe>
            </div>
            <p class="resume-fallback-note">
                If the preview does not load in your browser,
                <a href="/assets/resume/Hugo-Palafox-Resume.pdf">download the PDF directly.</a>
            </p>
        </div>
    </div>
</SectionContainer>

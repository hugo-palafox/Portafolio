@page "/projects/{Slug}"
@inject ProjectService ProjectService

<PageTitle>@(Project is null ? "Project Not Found" : $"{Project.Title} | Hugo Palafox")</PageTitle>

@if (Project is null)
{
    <SectionContainer>
        <PageHeader Eyebrow="Projects" Title="Project Not Found" Description="The requested case study slug does not match current placeholder data." />
        <ButtonLink Href="/projects" Text="Back to Projects" />
    </SectionContainer>
}
else
{
    <SectionContainer>
        <PageHeader Eyebrow="@Project.Category" Title="@Project.Title" Description="@Project.ShortSummary" />
        <div class="media media-hero">
            <img class="media-image" src="@Project.HeroImage" alt="@($"{Project.Title} hero image")" />
        </div>
    </SectionContainer>

    <SectionContainer>
        <div class="content-grid">
            <article class="card prose">
                <h2>Overview</h2>
                <p>@Project.ShortSummary</p>
                <h2>Problem</h2>
                <p>@Project.Problem</p>
                <h2>Architecture</h2>
                <p>@Project.ArchitectureSummary</p>
                <h2>My Role</h2>
                <p>@Project.Role</p>
                <h2>Technical Challenges</h2>
                <p>@Project.TechnicalChallenges</p>
                <h2>Tech Stack</h2>
                <TagList Tags="@Project.TechStack" />
                <h2>Outcome / Impact</h2>
                <p>@Project.Outcome</p>
                @if (HasMedia)
                {
                    <h2>@Project.MediaSectionTitle</h2>
                    @if (Project.MediaBlocks.Count > 0)
                    {
                        <div class="system-media-grid">
                            @foreach (var block in Project.MediaBlocks)
                            {
                                <section class="system-media-block" @key="block.Title">
                                    <h3 class="system-media-title">@block.Title</h3>
                                    <div class="media media-16x9 system-media-frame">
                                        <img class="media-image" src="@block.ImagePath" alt="@block.Title" loading="lazy" />
                                    </div>
                                    <p class="system-media-caption">@block.Caption</p>
                                </section>
                            }
                        </div>
                    }
                    else
                    {
                        <MediaTileGrid Items="@Project.GalleryImages" />
                    }
                }
            </article>
        </div>
    </SectionContainer>
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private Project? Project { get; set; }
    private bool HasMedia => Project is not null && (Project.MediaBlocks.Count > 0 || Project.GalleryImages.Count > 0);

    protected override void OnParametersSet()
    {
        Project = ProjectService.GetBySlug(Slug);
    }
}

@if (Items.Count > 0)
{
    <div class="media-grid">
        @foreach (var item in Items)
        {
            <button type="button" class="media media-tile media-tile-button" @onclick="() => OpenImage(item)" @key="item">
                <img class="media-image" src="@item" alt="Project media image" loading="lazy" />
            </button>
        }
    </div>
}

@if (SelectedImage is not null)
{
    <div class="lightbox-overlay" @onclick="CloseImage">
        <div class="lightbox-panel" @onclick:stopPropagation="true">
            <button type="button" class="lightbox-close" @onclick="CloseImage" aria-label="Close full image view">Close</button>
            <img class="lightbox-image" src="@SelectedImage" alt="Full-size project media image" />
        </div>
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<string> Items { get; set; } = Array.Empty<string>();

    private string? SelectedImage { get; set; }

    private void OpenImage(string imagePath)
    {
        SelectedImage = imagePath;
    }

    private void CloseImage()
    {
        SelectedImage = null;
    }
}
